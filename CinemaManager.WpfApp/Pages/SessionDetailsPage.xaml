<Page x:Class="CinemaManager.WpfApp.Pages.SessionDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Session Details">
    <Grid Margin="20">
        <StackPanel>
            <!-- Movie name -->
            <TextBlock x:Name="MovieNameText"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- Session details -->
            <TextBlock x:Name="GenreText" FontSize="16" Margin="0,5"/>
            <TextBlock x:Name="YearText" FontSize="16" Margin="0,5"/>
            <TextBlock x:Name="StartTimeText" FontSize="16" Margin="0,5"/>
            <TextBlock x:Name="DurationText" FontSize="16" Margin="0,5"/>
            <TextBlock x:Name="EndTimeText" FontSize="16" Margin="0,5"/>
            <TextBlock x:Name="SessionIdText" FontSize="14" Margin="0,20,0,0" Foreground="Gray"/>
        </StackPanel>
    </Grid>
</Page>
