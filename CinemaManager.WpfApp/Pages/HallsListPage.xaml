<Page x:Class="CinemaManager.WpfApp.Pages.HallsListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Halls">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Halls List"
                   FontSize="32"
                   FontWeight="Bold"
                   Margin="20"
                   Grid.Row="0"/>

        <ListBox x:Name="HallsListBox"  
                    Grid.Row="1"
                    Margin="20"
                    SelectionChanged="HallsListBox_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5">
                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"/>
                        <TextBlock>
                              <Run Text="Type: "/><Run Text="{Binding Type}"/>
                              <Run Text=" | Places:"/><Run Text="{Binding SeatsNumber}"/>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
